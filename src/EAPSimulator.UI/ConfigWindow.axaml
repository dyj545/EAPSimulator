<Window x:Class="EAPSimulator.UI.ConfigWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:EAPSimulator.UI.Views"
        Title="Configuration" Width="360" Height="620"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">
    <views:ConfigView DataContext="{Binding Config}"/>
</Window>
