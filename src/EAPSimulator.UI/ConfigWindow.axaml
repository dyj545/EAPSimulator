<Window x:Class="EAPSimulator.UI.ConfigWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:EAPSimulator.UI.Views"
        Title="Configuration" Width="720" Height="720"
        MinWidth="560" MinHeight="540"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ShowInTaskbar="False">
    <views:ConfigView DataContext="{Binding Config}"/>
</Window>
