<UserControl x:Class="EAPSimulator.UI.Views.MessageLogView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="6,3" Background="#2D2D2D">
            <DockPanel>
                <TextBlock Text="Message Log" FontWeight="Bold" DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="12"/>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Opacity="0.6" FontSize="11" Margin="8,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} / {1}">
                            <Binding Path="FilteredCount"/>
                            <Binding Path="TotalCount"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <Button Content="Clear" Command="{Binding ClearCommand}" DockPanel.Dock="Right"
                        Padding="8,2" HorizontalAlignment="Right" FontSize="11"/>
                <TextBox Text="{Binding FilterText}"
                         Padding="4,2" Margin="8,0,0,0" DockPanel.Dock="Right" Width="160"
                         FontSize="11" Watermark="搜索..."/>
            </DockPanel>
        </Border>

        <!-- Category Filter Panel -->
        <Border Grid.Row="1" Padding="6,3" Background="#252525">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="类型:" Opacity="0.6" VerticalAlignment="Center" FontSize="11"/>
                <CheckBox Content="SYS" IsChecked="{Binding ShowSystem}" FontSize="11"
                          Foreground="#FF9800"/>
                <CheckBox Content="Send" IsChecked="{Binding ShowSend}" FontSize="11"
                          Foreground="#2196F3"/>
                <CheckBox Content="Recv" IsChecked="{Binding ShowReceive}" FontSize="11"
                          Foreground="#4CAF50"/>
                <CheckBox Content="ERR" IsChecked="{Binding ShowError}" FontSize="11"
                          Foreground="#F44336"/>
                <Border Width="1" Background="#555" Margin="4,2"/>
                <Button Content="全选/反选" Command="{Binding ToggleAllFiltersCommand}"
                        Padding="6,1" FontSize="10" Opacity="0.7"/>
                <Border Width="1" Background="#555" Margin="4,2"/>
                <CheckBox Content="消息抬头筛选" IsChecked="{Binding HeaderFilterEnabled}" FontSize="11"
                          Foreground="#9C27B0"/>
            </StackPanel>
        </Border>

        <!-- Header Filter Panel (collapsible) -->
        <Border Grid.Row="2" Padding="6,3" Background="#1E1E1E"
                IsVisible="{Binding HeaderFilterEnabled}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                    <TextBlock Text="消息抬头:" Opacity="0.6" VerticalAlignment="Center" FontSize="11"/>
                    <Button Content="全选" Command="{Binding ToggleAllHeadersCommand}"
                            Padding="6,1" FontSize="10"/>
                    <TextBlock Text="点击单项可单独筛选" Opacity="0.4" VerticalAlignment="Center" FontSize="10"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding HeaderFilters}"
                         MaxHeight="120"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="1" Padding="4,2" CornerRadius="3"
                                    Background="#333333" Cursor="Hand">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <CheckBox IsChecked="{Binding IsEnabled}" FontSize="10"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Header}" FontSize="11"
                                               VerticalAlignment="Center" FontFamily="Consolas,monospace"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Message List -->
        <ListBox Grid.Row="3" ItemsSource="{Binding FilteredEntries}"
                 SelectedItem="{Binding SelectedEntry}"
                 Background="Transparent"
                 FontSize="12">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="1,1" BorderThickness="0,0,0,0.5" BorderBrush="#333333">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}"
                                       Width="85" Opacity="0.6" FontSize="11"/>
                            <TextBlock Text="{Binding DirectionLabel}" FontWeight="Bold"
                                       Foreground="{Binding DirectionColor}" Width="30" FontSize="11"/>
                            <TextBlock Text="{Binding Protocol}" Width="80" Opacity="0.7" FontSize="11"/>
                            <TextBlock Text="{Binding Content}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Detail label -->
        <TextBlock Grid.Row="4" Text="Detail" FontWeight="SemiBold" Padding="6,2" FontSize="11" Background="#2D2D2D"/>

        <!-- Detail Panel -->
        <TextBox Grid.Row="5" Text="{Binding DetailText, Mode=OneWay}"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 FontFamily="Consolas,monospace"
                 FontSize="11"
                 Padding="6"/>
    </Grid>
</UserControl>
