<UserControl x:Class="EAPSimulator.UI.Views.StatusPanelView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:EAPSimulator.UI.Converters">
    <UserControl.Resources>
        <converters:HexToBrushConverter x:Key="HexToBrush"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <!-- Title -->
            <TextBlock Text="Status Panel" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
            <Border Height="1" Opacity="0.2" Background="Gray" Margin="0,0,0,8"/>

            <!-- Connection State (主协议: SECS / Custom / 独立 Host 模式共用此灯) -->
            <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="12" Height="12" Fill="{Binding ConnectionStateColor}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Main: " Opacity="0.6" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ConnectionState}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- GEM State -->
            <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="GEM State: " Opacity="0.6"/>
                        <TextBlock Grid.Column="1" Text="{Binding GemState}" FontWeight="SemiBold"/>
                    </Grid>
                    <!-- GEM State Switch Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding CanSwitchState}">
                        <Button Content="Local" Command="{Binding SwitchToOnlineLocalCommand}"
                                IsEnabled="{Binding !IsOnlineLocal}" FontSize="11" Padding="8,3"
                                Background="#4CAF50" Foreground="White"/>
                        <Button Content="Remote" Command="{Binding SwitchToOnlineRemoteCommand}"
                                IsEnabled="{Binding !IsOnlineRemote}" FontSize="11" Padding="8,3"
                                Background="#2196F3" Foreground="White"/>
                        <Button Content="Offline" Command="{Binding SwitchToOfflineCommand}"
                                IsEnabled="{Binding !IsOffline}" FontSize="11" Padding="8,3"
                                Background="#FF9800" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Protocol / Role -->
            <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,4">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Protocol: " Opacity="0.6"/>
                        <TextBlock Text="{Binding ProtocolType}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Role: " Opacity="0.6"/>
                        <TextBlock Text="{Binding Role}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Host Channels — runtime status of every configured MES/RMS/WMS channel.
                 Each row = dot + name + status text + endpoint summary + connect/disconnect.
                 The whole card hides when no channels are configured. -->
            <Border CornerRadius="4" Padding="8,6" Margin="0,0,0,4"
                    IsVisible="{Binding HostChannels.Count}">
                <StackPanel>
                    <TextBlock Text="Host Channels" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding HostChannels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,3" ToolTip.Tip="{Binding StatusText}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10"
                                                 Fill="{Binding StatusColor, Converter={StaticResource HexToBrush}}"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding EndpointSummary}" Opacity="0.55"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <!-- Toggle button: Connect when down, Disconnect when up.
                                             Both commands live on HostChannelViewModel; MainViewModel
                                             listens to ConnectRequested/DisconnectRequested events. -->
                                        <Button Grid.Column="2" Content="Connect"
                                                Command="{Binding ConnectCommand}"
                                                IsVisible="{Binding !IsConnected}"
                                                Padding="8,2" FontSize="11"/>
                                        <Button Grid.Column="2" Content="Disconnect"
                                                Command="{Binding DisconnectCommand}"
                                                IsVisible="{Binding IsConnected}"
                                                Classes="danger"
                                                Padding="8,2" FontSize="11"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Height="1" Opacity="0.2" Background="Gray" Margin="0,4"/>

            <!-- Status Variables -->
            <TextBlock Text="Status Variables" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <DataGrid ItemsSource="{Binding StatusVariables}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      MaxHeight="200" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SVID" Binding="{Binding Svid}" Width="50"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="70"/>
                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="50"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Height="1" Opacity="0.2" Background="Gray" Margin="0,4"/>

            <!-- Alarms -->
            <TextBlock Text="Alarms" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <DataGrid ItemsSource="{Binding Alarms}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      MaxHeight="150" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ALID" Binding="{Binding Alid}" Width="50"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTemplateColumn Header="Status" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" FontWeight="Bold" Foreground="{Binding StatusColor}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Height="1" Opacity="0.2" Background="Gray" Margin="0,4"/>

            <!-- Collection Events -->
            <TextBlock Text="Collection Events" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <DataGrid ItemsSource="{Binding CollectionEvents}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      MaxHeight="150" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CEID" Binding="{Binding Ceid}" Width="50"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
