<UserControl x:Class="EAPSimulator.Wpf.Views.MessageEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
             xmlns:vm="clr-namespace:EAPSimulator.Wpf.ViewModels"
             Foreground="#E0E0E0" FontSize="12">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ═══ Context Menus ═══ -->

        <!-- Message-level context menu -->
        <ContextMenu x:Key="MsgContextMenu">
            <MenuItem Header="添加子节点" Click="OnMsgAddChild">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="PlusCircle" Foreground="#6A9955" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="克隆消息" Click="OnMsgDuplicate">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="ContentCopy" Foreground="#569CD6" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="删除消息" Click="OnMsgDelete">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="Delete" Foreground="#F44747" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- Item-level context menu -->
        <ContextMenu x:Key="ItemContextMenu">
            <MenuItem Header="编辑字段..." Click="OnEditField" FontWeight="SemiBold">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="Pencil" Foreground="#9CDCFE" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="添加子节点" Click="OnAddChild">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="PlusCircle" Foreground="#6A9955" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="添加同级节点" Click="OnAddSibling">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="PlusCircleOutline" Foreground="#6A9955" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="复制节点" Click="OnCopyItem">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="ContentCopy" Foreground="#569CD6" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="删除节点" Click="OnDeleteItem">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="Delete" Foreground="#F44747" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="上移" Click="OnMoveUp">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="ArrowUp" Foreground="#888" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="下移" Click="OnMoveDown">
                <MenuItem.Icon>
                    <material:PackIconMaterial Kind="ArrowDown" Foreground="#888" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- Tree background context menu -->
        <ContextMenu x:Key="TreeContextMenu">
            <MenuItem Header="全部展开" Click="OnExpandAll"/>
            <MenuItem Header="全部折叠" Click="OnCollapseAll"/>
        </ContextMenu>
    </UserControl.Resources>

    <DockPanel>
        <!-- ═══ Toolbar ═══ -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="6,3">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="4,0,0,0">
                    <Button Click="OnSendClick"
                            Background="#4CAF50" Foreground="White" Padding="10,3" FontSize="11">
                        <StackPanel Orientation="Horizontal">
                            <material:PackIconMaterial Kind="Send" Width="14" Height="14" Margin="0,0,4,0"/>
                            <TextBlock Text=" 发送 (Ctrl+S)" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <WrapPanel VerticalAlignment="Center">
                    <Button Click="OnBrowseClick" ToolTip="打开消息模板文件"
                            Padding="5,1" FontSize="13" Margin="0,0,4,0">
                        <material:PackIconMaterial Kind="FolderOpenOutline" Width="16" Height="16"/>
                    </Button>
                    <Button Click="OnSaveClick" ToolTip="保存消息模板"
                            Padding="5,1" FontSize="13" Margin="0,0,8,0">
                        <material:PackIconMaterial Kind="Floppy" Width="16" Height="16"/>
                    </Button>
                    <TextBlock x:Name="FilePathText" Text="" Foreground="#808080"
                               VerticalAlignment="Center" FontSize="10"
                               TextTrimming="CharacterEllipsis" MaxWidth="160" Margin="0,0,8,0"/>
                    <Border Width="1" Background="#555" Margin="4,2" VerticalAlignment="Stretch"/>
                    <material:PackIconMaterial Kind="PlusCircle" Foreground="#6A9955" VerticalAlignment="Center"
                               Width="16" Height="16" Margin="4,0,2,0"/>
                    <ComboBox x:Name="AddMessageCombo" Width="220" Height="22" FontSize="11"
                              Padding="4,0" Margin="0,0,4,0"/>
                    <Button Click="OnAddMessageClick"
                            Background="#4CAF50" Foreground="White" Padding="8,2" FontSize="11" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <material:PackIconMaterial Kind="PlusCircle" Width="14" Height="14" Margin="0,0,4,0"/>
                            <TextBlock Text=" 添加消息" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnDeleteClick"
                            Background="#F44747" Foreground="White" Padding="8,2" FontSize="11" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <material:PackIconMaterial Kind="Delete" Width="14" Height="14" Margin="0,0,4,0"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnDuplicateClick"
                            Padding="8,2" FontSize="11">
                        <StackPanel Orientation="Horizontal">
                            <material:PackIconMaterial Kind="ContentCopy" Width="14" Height="14" Margin="0,0,4,0"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </DockPanel>
        </Border>

        <!-- ═══ Status Bar ═══ -->
        <Border DockPanel.Dock="Bottom" Background="#252525" Padding="6,2">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#808080"/>
        </Border>

        <!-- ═══ TreeView ═══ -->
        <TreeView x:Name="MessageTreeView"
                  ItemsSource="{Binding Groups}"
                  BorderThickness="0" Padding="2"
                  Background="Transparent" Foreground="#E0E0E0"
                  SelectedItemChanged="OnTreeSelectionChanged"
                  ContextMenu="{StaticResource TreeContextMenu}"
                  AllowDrop="True"
                  MouseMove="OnTreeMouseMove"
                  PreviewMouseLeftButtonDown="OnTreePreviewMouseDown"
                  PreviewKeyDown="OnTreePreviewKeyDown">

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#E0E0E0"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </TreeView.ItemContainerStyle>

            <TreeView.Resources>
                <!-- Level 1: Group -->
                <HierarchicalDataTemplate DataType="{x:Type vm:MessageGroupViewModel}"
                                          ItemsSource="{Binding Pairs}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,1">
                        <TextBlock Text="{Binding DisplayText}" FontSize="13" FontWeight="Bold"
                                   Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    </StackPanel>
                </HierarchicalDataTemplate>

                <!-- Level 2: Pair -->
                <HierarchicalDataTemplate DataType="{x:Type vm:MessagePairViewModel}"
                                          ItemsSource="{Binding Messages}">
                    <Grid VerticalAlignment="Center" Margin="2,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*" MaxWidth="200"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#C586C0" VerticalAlignment="Center" Grid.Column="0"/>
                        <TextBlock Text="  —  " Foreground="#555" VerticalAlignment="Center" FontSize="12" Grid.Column="1"/>
                        <TextBox Grid.Column="2" Text="{Binding Description, UpdateSourceTrigger=LostFocus}" FontSize="12"
                                 Foreground="#DCDCAA" Background="Transparent" BorderThickness="0"
                                 Padding="0" MinWidth="60"
                                 VerticalContentAlignment="Center" Height="20"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
                            <Button Width="20" Height="18" Background="Transparent" BorderThickness="0"
                                    ToolTip="克隆消息组" FontSize="11"
                                    Click="OnPairCloneClick" Tag="{Binding}">
                                <material:PackIconMaterial Kind="ContentCopy" Width="12" Height="12"/>
                            </Button>
                            <Button Width="20" Height="18" Background="Transparent" BorderThickness="0"
                                    ToolTip="删除消息组" FontSize="11"
                                    Click="OnPairDeleteClick" Tag="{Binding}">
                                <material:PackIconMaterial Kind="Delete" Width="12" Height="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </HierarchicalDataTemplate>

                <!-- Level 3: Message -->
                <HierarchicalDataTemplate DataType="{x:Type vm:SecsMessageViewModel}"
                                          ItemsSource="{Binding RootItem.Children}">
                    <Grid VerticalAlignment="Center" Margin="2,1"
                          ContextMenu="{StaticResource MsgContextMenu}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Grid.Column="0" Margin="0,0,4,0">
                            <Run Text="S" Foreground="#569CD6"/>
                            <Run Text="{Binding Stream, Mode=OneWay}" Foreground="#B5CEA8"/>
                            <Run Text="F" Foreground="#569CD6"/>
                            <Run Text="{Binding Function, Mode=OneWay}" Foreground="#B5CEA8"/>
                        </TextBlock>
                        <CheckBox IsChecked="{Binding WBit}" VerticalAlignment="Center" Margin="2,0,0,0"
                                  Width="14" Height="14" ToolTip="W-Bit" Grid.Column="1"/>
                        <TextBlock Text="W" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                   Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,4,0" Grid.Column="2"/>
                        <TextBox Grid.Column="3" Text="{Binding Name, UpdateSourceTrigger=LostFocus}" FontSize="12"
                                 Foreground="#DCDCAA" Background="Transparent" BorderThickness="0"
                                 MinWidth="60" MaxWidth="160"
                                 VerticalContentAlignment="Center" Height="20"
                                 Padding="2,0"/>
                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Width="20" Height="18" Background="Transparent" BorderThickness="0"
                                    ToolTip="添加子节点" FontSize="11"
                                    Click="OnMsgAddChildBtn" Tag="{Binding}">
                                <material:PackIconMaterial Kind="PlusCircle" Width="12" Height="12"/>
                            </Button>
                            <Button Width="20" Height="18" Background="Transparent" BorderThickness="0"
                                    ToolTip="克隆" FontSize="11"
                                    Click="OnMsgCloneBtn" Tag="{Binding}">
                                <material:PackIconMaterial Kind="ContentCopy" Width="12" Height="12"/>
                            </Button>
                            <Button Width="20" Height="18" Background="Transparent" BorderThickness="0"
                                    ToolTip="删除" FontSize="11"
                                    Click="OnMsgDeleteBtn" Tag="{Binding}">
                                <material:PackIconMaterial Kind="Delete" Width="12" Height="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </HierarchicalDataTemplate>

                <!-- Level 4: Item (recursive) -->
                <HierarchicalDataTemplate DataType="{x:Type vm:SecsItemViewModel}"
                                          ItemsSource="{Binding Children}">
                    <Border Background="Transparent" Margin="-4,-1,-4,-1"
                            ContextMenu="{StaticResource ItemContextMenu}">
                        <StackPanel Orientation="Horizontal" Margin="5,1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayTypeName}" FontSize="12"
                                       FontFamily="Consolas" Foreground="#569CD6"
                                       FontWeight="SemiBold" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayAlias}" FontSize="11"
                                       Foreground="#9CDCFE" VerticalAlignment="Center"
                                       Visibility="{Binding HasAlias, Converter={StaticResource BoolToVis}}"
                                       Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding DisplayValue}" FontSize="11"
                                       Foreground="#E0E0E0" VerticalAlignment="Center"
                                       Visibility="{Binding HasValue, Converter={StaticResource BoolToVis}}"/>
                            <StackPanel Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
                                <Button Width="18" Height="16" Background="Transparent" BorderThickness="0"
                                        ToolTip="添加子节点(List)"
                                        Click="OnItemAddChild" Tag="{Binding}"
                                        Visibility="{Binding IsList, Converter={StaticResource BoolToVis}}"
                                        FontSize="10">
                                    <material:PackIconMaterial Kind="PlusBoxOutline" Width="12" Height="12"/>
                                </Button>
                                <Button Width="18" Height="16" Background="Transparent" BorderThickness="0"
                                        ToolTip="删除"
                                        Click="OnItemDelete" Tag="{Binding}"
                                        FontSize="10">
                                    <material:PackIconMaterial Kind="Delete" Width="12" Height="12"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </HierarchicalDataTemplate>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</UserControl>
