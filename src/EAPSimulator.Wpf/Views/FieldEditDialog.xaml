<Window x:Class="EAPSimulator.Wpf.Views.FieldEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        xmlns:vm="clr-namespace:EAPSimulator.Wpf.ViewModels"
        Title="字段编辑" Width="480" Height="580"
        MinWidth="400" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" ResizeMode="CanResize">

    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Click="OnOkClick" Background="#4CAF50" Foreground="White"
                    Padding="16,6" Margin="0,0,8,0" FontSize="12">
                <StackPanel Orientation="Horizontal">
                    <material:PackIconMaterial Kind="Check" Width="14" Height="14" Margin="0,0,4,0"/>
                </StackPanel>
            </Button>
            <Button Click="OnCancelClick" Padding="16,6" FontSize="12">
                <StackPanel Orientation="Horizontal">
                    <material:PackIconMaterial Kind="Close" Width="14" Height="14" Margin="0,0,4,0"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- ═══ Basic Info ═══ -->
                <Border Background="#252525" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="基本信息" FontWeight="SemiBold" Foreground="#569CD6" FontSize="13" Margin="0,0,0,6"/>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="类型:" Width="70" VerticalAlignment="Center" FontSize="12" Foreground="#808080"/>
                            <ComboBox x:Name="TypeNameCombo"
                                      ItemsSource="{x:Static vm:SecsItemViewModel.TypeNames}"
                                      MinWidth="120" Height="26" FontSize="12"
                                      FontFamily="Consolas" Padding="4,0"
                                      Background="#1E1E1E" Foreground="#E0E0E0"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="别名:" Width="70" VerticalAlignment="Center" FontSize="12" Foreground="#808080"/>
                            <TextBox x:Name="AliasBox" MinWidth="200" FontSize="12" Padding="4,2" VerticalContentAlignment="Center"
                                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="描述:" Width="70" VerticalAlignment="Center" FontSize="12" Foreground="#808080"/>
                            <TextBox x:Name="DescriptionBox" MinWidth="200" FontSize="12" Padding="4,2" VerticalContentAlignment="Center"
                                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="当前值:" Width="70" VerticalAlignment="Center" FontSize="12" Foreground="#808080"/>
                            <TextBox x:Name="ValueText" MinWidth="200" FontSize="12" Padding="4,2" VerticalContentAlignment="Center"
                                     FontFamily="Consolas" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ Format & Default ═══ -->
                <Border Background="#252525" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="格式与默认值" FontWeight="SemiBold" Foreground="#4CAF50" FontSize="13" Margin="0,0,0,6"/>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="格式:" Width="70" VerticalAlignment="Center" FontSize="12" Foreground="#808080"/>
                            <TextBox x:Name="FormatBox" MinWidth="200" FontSize="12" Padding="4,2" VerticalContentAlignment="Center"
                                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="NLB:" Width="70" VerticalAlignment="Center" FontSize="12" Foreground="#808080"/>
                            <TextBox x:Name="NlbBox" MinWidth="200" FontSize="12" Padding="4,2" VerticalContentAlignment="Center"
                                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="默认值:" Width="70" VerticalAlignment="Center" FontSize="12" Foreground="#808080"/>
                            <TextBox x:Name="DefaultValueBox" MinWidth="200" FontSize="12" Padding="4,2" VerticalContentAlignment="Center"
                                     FontFamily="Consolas" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ Value Mapping ═══ -->
                <Border Background="#252525" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="值映射 (Value Mapping)" FontWeight="SemiBold" Foreground="#FF9800" FontSize="13" VerticalAlignment="Center"/>
                            <Button Click="OnAddMapping" Background="#4CAF50" Foreground="White" Padding="8,2" FontSize="11" DockPanel.Dock="Right">
                                <StackPanel Orientation="Horizontal">
                                    <material:PackIconMaterial Kind="Plus" Width="14" Height="14" Margin="0,0,4,0"/>
                                </StackPanel>
                            </Button>
                        </DockPanel>
                        <ItemsControl x:Name="MappingList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ValueMappingEntry}">
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding Value}" FontSize="11" Padding="3,2"
                                                 FontFamily="Consolas" VerticalContentAlignment="Center"
                                                 Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                                        <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555"/>
                                        <TextBox Grid.Column="2" Text="{Binding DisplayText}" FontSize="11" Padding="3,2"
                                                 VerticalContentAlignment="Center"
                                                 Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                                        <Button Grid.Column="3" Click="OnRemoveMapping" Tag="{Binding}"
                                                Padding="4,0" FontSize="11" Background="Transparent" Foreground="#F44747">
                                            <material:PackIconMaterial Kind="Close" Width="14"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="将原始值映射为可读的显示文本" FontSize="11" Foreground="#555" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
