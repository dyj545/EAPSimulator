<UserControl x:Class="EAPSimulator.Wpf.Views.AutoReplyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
             Foreground="#E0E0E0">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>    <DockPanel>
        <!-- ═══ Top: Toolbar ═══ -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="4,2">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Command="{Binding SaveConfigCommand}"
                            Background="#4CAF50" Foreground="White" Padding="8,2" FontSize="11" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <material:PackIconMaterial Kind="Floppy" Width="14" Height="14" Margin="0,0,4,0"/>
                            <TextBlock Text=" 保存" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#808080"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- ═══ Main Content: Scenario List + Steps + Detail ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="180" MaxWidth="500"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Scenario + Step List -->
            <DockPanel Grid.Column="0">
                <!-- Scenario toolbar -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,2">
                    <Button Command="{Binding AddScenarioCommand}"
                            Background="#4CAF50" Foreground="White" Padding="6,2" FontSize="11" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <material:PackIconMaterial Kind="PlusCircle" Width="14" Height="14" Margin="0,0,4,0"/>
                            <TextBlock Text=" 添加场景" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button Content="删除" Command="{Binding DeleteScenarioCommand}"
                            Background="#F44747" Foreground="White" Padding="6,2" FontSize="11"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Scenarios}"
                         SelectedItem="{Binding SelectedScenario}"
                         Padding="2" MaxHeight="150" Background="#252525" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#E0E0E0"/>
                                <TextBlock Text=" (" FontSize="11" Foreground="#808080"/>
                                <TextBlock Text="{Binding Steps.Count}" FontSize="11" Foreground="#808080"/>
                                <TextBlock Text=" 步)" FontSize="11" Foreground="#808080"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Step toolbar -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,2">
                    <TextBlock Text="步骤:" FontSize="11" FontWeight="SemiBold"
                               Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Command="{Binding AddStepCommand}"
                            Background="#4CAF50" Foreground="White" Padding="6,1" FontSize="10" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <material:PackIconMaterial Kind="PlusCircle" Width="12" Height="12" Margin="0,0,4,0"/>
                            <TextBlock Text=" 添加步骤" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button Content="删除" Command="{Binding DeleteStepCommand}"
                            Background="#F44747" Foreground="White" Padding="6,1" FontSize="10" Margin="0,0,4,0"/>
                    <Button Padding="4,0" FontSize="11"
                            Command="{Binding MoveStepUpCommand}">
                        <material:PackIconMaterial Kind="ArrowUp" Width="12" Height="12"/>
                    </Button>
                    <Button Padding="4,0" FontSize="11"
                            Command="{Binding MoveStepDownCommand}">
                        <material:PackIconMaterial Kind="ArrowDown" Width="12" Height="12"/>
                    </Button>
                </StackPanel>
                <ListBox ItemsSource="{Binding SelectedScenario.Steps}"
                         SelectedItem="{Binding SelectedStep}"
                         Padding="2" Background="#252525" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}" FontSize="11"
                                       FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                       Foreground="#B5CEA8"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="#444"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right: Step Detail -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="8,4">
                <StackPanel>
                    <!-- Scenario Settings -->
                    <Border Background="#252525" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="场景设置" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#569CD6" Margin="0,0,0,6"/>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="名称:" Foreground="#808080" Width="40" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding SelectedScenario.Name}" Padding="4,2"
                                         Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="描述:" Foreground="#808080" Width="40" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding SelectedScenario.Description}" Padding="4,2"
                                         Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                            </DockPanel>
                            <CheckBox IsChecked="{Binding SelectedScenario.Enabled}"
                                      Content="启用" Foreground="#E0E0E0" Margin="0,0,12,0"/>
                            <CheckBox IsChecked="{Binding SelectedScenario.Loop}"
                                      Content="循环执行" Foreground="#E0E0E0"/>
                        </StackPanel>
                    </Border>

                    <!-- Step Detail -->
                    <Border Background="#252525" CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="步骤详情" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#4CAF50" Margin="0,0,0,6"/>

                            <!-- Trigger Type -->
                            <TextBlock Text="触发类型:" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#569CD6" Margin="0,0,0,4"/>
                            <ComboBox x:Name="TriggerTypeCombo" Padding="4,2" FontSize="11" Background="#1E1E1E"
                                      Foreground="#E0E0E0" BorderBrush="#3F3F46" Margin="0,0,0,4"/>

                            <!-- SECS Trigger -->
                            <StackPanel x:Name="SecsTriggerPanel" Margin="0,0,0,4">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Stream:" Foreground="#808080" VerticalAlignment="Center" Margin="0,0,6,0" Width="60"/>
                                    <TextBox Text="{Binding SelectedStep.Stream}" Width="50" Padding="4,2"
                                             Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"
                                             FontFamily="Consolas" Margin="0,0,12,0" VerticalContentAlignment="Center"/>
                                    <TextBlock Text="Function:" Foreground="#808080" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Text="{Binding SelectedStep.Function}" Width="50" Padding="4,2"
                                             Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"
                                             FontFamily="Consolas" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action Type -->
                            <TextBlock Text="动作类型:" FontSize="11" FontWeight="SemiBold"
                                       Foreground="#4CAF50" Margin="0,8,0,4"/>
                            <ComboBox x:Name="ActionTypeCombo" Padding="4,2" FontSize="11" Background="#1E1E1E"
                                      Foreground="#E0E0E0" BorderBrush="#3F3F46" Margin="0,0,0,4"/>

                            <!-- SECS Reply Action -->
                            <StackPanel x:Name="SecsActionPanel" Margin="0,0,0,4">
                                <TextBlock Text="模板:" Foreground="#808080" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding SelectedStep.ActionTemplateName}" Padding="4,2"
                                         Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
