<UserControl x:Class="EAPSimulator.Wpf.Views.MessageLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
             Foreground="#E0E0E0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- ═══ Toolbar ═══ -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="6,3">
            <DockPanel>
                <TextBlock Text="Message Log" FontWeight="Bold" DockPanel.Dock="Left"
                           VerticalAlignment="Center" FontSize="12" Foreground="#E0E0E0"/>
                <Button Click="OnClearClick" DockPanel.Dock="Right"
                        Padding="8,2" HorizontalAlignment="Right" FontSize="11">
                    <StackPanel Orientation="Horizontal">
                        <material:PackIconMaterial Kind="Eraser" Width="14" Height="14" Margin="0,0,4,0"/>
                    </StackPanel>
                </Button>
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,2" Margin="8,0,0,0" DockPanel.Dock="Right" Width="160"
                         FontSize="11" Background="#1E1E1E" Foreground="#E0E0E0"
                         BorderBrush="#3F3F46"/>
            </DockPanel>
        </Border>

        <!-- ═══ Category Filter ═══ -->
        <Border Grid.Row="1" Background="#252525" Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="类型:" Foreground="#808080" VerticalAlignment="Center" FontSize="11"/>
                <CheckBox x:Name="ShowSystem" Content="SYS" FontSize="11" Margin="12,0,0,0"
                          Foreground="#FF9800"/>
                <CheckBox x:Name="ShowSend" Content="Send" FontSize="11" Margin="8,0,0,0"
                          Foreground="#2196F3"/>
                <CheckBox x:Name="ShowRecv" Content="Recv" FontSize="11" Margin="8,0,0,0"
                          Foreground="#4CAF50"/>
                <CheckBox x:Name="ShowError" Content="ERR" FontSize="11" Margin="8,0,0,0"
                          Foreground="#F44336"/>
                <Border Width="1" Background="#555" Margin="8,2" VerticalAlignment="Stretch"/>
                <Button Padding="6,1" FontSize="10" Foreground="#808080">
                    <StackPanel Orientation="Horizontal">
                        <material:PackIconMaterial Kind="SelectGroup" Width="12" Height="12" Margin="0,0,4,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══ Message List ═══ -->
        <ListBox Grid.Row="3" ItemsSource="{Binding LogEntries}"
                 Background="Transparent" BorderThickness="0"
                 FontSize="12" Padding="2"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="1,2" BorderThickness="0,0,0,0.5" BorderBrush="#333">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Timestamp}" Width="85"
                                       Foreground="#808080" FontSize="11" Margin="2,0"/>
                            <TextBlock Text="{Binding Direction}" FontWeight="Bold"
                                       Foreground="#4CAF50" Width="30" FontSize="11" Margin="4,0"/>
                            <TextBlock Text="{Binding StreamFunction}" Width="80"
                                       Foreground="#888" FontSize="11" Margin="4,0"/>
                            <TextBlock Text="{Binding Content}" Foreground="#E0E0E0" FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ═══ Detail Label ═══ -->
        <TextBlock Grid.Row="4" Text="Detail" FontWeight="SemiBold" Padding="6,2"
                   FontSize="11" Background="#2D2D2D" Foreground="#E0E0E0"/>

        <!-- ═══ Detail Panel ═══ -->
        <TextBox Grid.Row="5" x:Name="DetailText"
                 IsReadOnly="True" TextWrapping="Wrap"
                 FontFamily="Consolas" FontSize="11"
                 Padding="6" Background="#1E1E1E" Foreground="#E0E0E0"
                 BorderBrush="#3F3F46"/>
    </Grid>
</UserControl>
