<UserControl x:Class="EAPSimulator.Wpf.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
             Foreground="#E0E0E0" FontFamily="Microsoft YaHei" FontSize="12">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12" MaxWidth="400">
            <!-- ═══ Title ═══ -->
            <TextBlock Text="Configuration" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
            <Border Height="1" Background="#444" Margin="0,0,0,8"/>

            <!-- ═══ HSMS Connection ═══ -->
            <TextBlock Text="HSMS Connection" FontSize="13" FontWeight="SemiBold"
                       Foreground="#888" Margin="0,0,0,4"/>

            <TextBlock Text="Connection Mode:" Foreground="#808080"/>
            <ComboBox x:Name="ConnectionModeCombo" Margin="0,2,0,2" Height="28"
                      Padding="6,3" Background="#1E1E1E" Foreground="#E0E0E0"
                      BorderBrush="#3F3F46" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Passive"/>
                <ComboBoxItem Content="Alternating"/>
            </ComboBox>
            <TextBlock x:Name="ConnectionModeHint" Text="Active: 主动连接设备"
                       FontSize="11" Foreground="#666"
                       TextWrapping="Wrap" Margin="0,0,0,6"/>

            <TextBlock Text="Local IP:" Foreground="#808080"/>
            <TextBox Text="{Binding LocalHost, FallbackValue=0.0.0.0}" Margin="0,2,0,6" Padding="4,2"
                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Local Port:" Foreground="#808080"/>
            <TextBox Text="{Binding LocalPort, FallbackValue=5000}" Margin="0,2,0,6" Padding="4,2"
                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Remote IP:" Foreground="#808080"/>
            <TextBox Text="{Binding RemoteHost, FallbackValue=127.0.0.1}" Margin="0,2,0,6" Padding="4,2"
                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Remote Port:" Foreground="#808080"/>
            <TextBox Text="{Binding RemotePort, FallbackValue=5000}" Margin="0,2,0,6" Padding="4,2"
                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Device ID:" Foreground="#808080"/>
            <TextBox Text="{Binding DeviceId, FallbackValue=1}" Margin="0,2,0,6" Padding="4,2"
                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"
                     VerticalContentAlignment="Center"/>

            <CheckBox Content="Accept Communication (S1F13→ACK)" IsChecked="{Binding AcceptCommunication}"
                      Foreground="#E0E0E0" Margin="0,4,0,6"/>

            <Border Height="1" Background="#444" Margin="0,8"/>

            <!-- ═══ Timeouts ═══ -->
            <TextBlock Text="Timeouts (ms)" FontSize="13" FontWeight="SemiBold"
                       Foreground="#888" Margin="0,0,0,4"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="T3:" VerticalAlignment="Center" Foreground="#808080"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding T3Timeout, FallbackValue=45}" Margin="0,2"
                         Padding="4,2" VerticalContentAlignment="Center"
                         Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="T5:" VerticalAlignment="Center" Foreground="#808080"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding T5Timeout, FallbackValue=10}" Margin="0,2"
                         Padding="4,2" VerticalContentAlignment="Center"
                         Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="T6:" VerticalAlignment="Center" Foreground="#808080"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding T6Timeout, FallbackValue=5}" Margin="0,2"
                         Padding="4,2" VerticalContentAlignment="Center"
                         Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="T7:" VerticalAlignment="Center" Foreground="#808080"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding T7Timeout, FallbackValue=10}" Margin="0,2"
                         Padding="4,2" VerticalContentAlignment="Center"
                         Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="T8:" VerticalAlignment="Center" Foreground="#808080"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding T8Timeout, FallbackValue=5}" Margin="0,2"
                         Padding="4,2" VerticalContentAlignment="Center"
                         Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
            </Grid>

            <Border Height="1" Background="#444" Margin="0,8"/>

            <!-- ═══ Custom Protocol ═══ -->
            <TextBlock Text="Custom Protocol" FontSize="13" FontWeight="SemiBold"
                       Foreground="#888" Margin="0,0,0,4"/>

            <TextBlock Text="Host:" Foreground="#808080"/>
            <TextBox Text="{Binding CustomHost, FallbackValue=127.0.0.1}" Margin="0,2,0,6" Padding="4,2"
                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Port:" Foreground="#808080"/>
            <TextBox Text="{Binding CustomPort, FallbackValue=6000}" Margin="0,2,0,6" Padding="4,2"
                     Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Config File:" Foreground="#808080"/>
            <DockPanel Margin="0,2,0,6">
                <Button Click="OnBrowseCustomConfigClick"
                        DockPanel.Dock="Right" Padding="8,2" Margin="4,0,0,0"
                        Width="32" ToolTip="选择配置文件">
                    <material:PackIconMaterial Kind="FolderOpen" Width="16" Height="16"/>
                </Button>
                <TextBox Text="{Binding CustomConfigPath, FallbackValue=custom_protocol.json}"
                         Padding="4,2" VerticalContentAlignment="Center"
                         Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#3F3F46"/>
            </DockPanel>

            <CheckBox Content="Server Mode" IsChecked="{Binding CustomIsServer}"
                      Foreground="#E0E0E0" Margin="0,4"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
