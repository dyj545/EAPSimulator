<mahApps:MetroWindow x:Class="EAPSimulator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mahApps="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:material="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        xmlns:views="clr-namespace:EAPSimulator.Wpf.Views"
        Title="EAP Simulator - SECS/GEM &amp; Custom Protocol"
        Height="800" Width="1400"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        GlowBrush="{DynamicResource AccentBrush}"
        WindowTransitionsEnabled="False"
        ResizeMode="CanResizeWithGrip"
        ShowTitleBar="True"
        ShowCloseButton="True">

    <DockPanel Background="#1A1A1A">
        <!-- ═══ Toolbar ═══ -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Protocol:" Foreground="#808080" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                <ComboBox x:Name="ProtocolTypeCombo" Width="120" FontSize="12"
                          SelectedIndex="0" Padding="4,2" Margin="0,0,8,0">
                    <ComboBoxItem Content="SECS/GEM"/>
                    <ComboBoxItem Content="Custom"/>
                </ComboBox>

                <Border Width="1" Background="#555" Margin="4,2" VerticalAlignment="Stretch"/>

                <Button x:Name="ConnectButton"
                        Background="#4CAF50" Foreground="White"
                        Click="OnStartListening" Padding="12,4" Margin="4,0"
                        FontWeight="SemiBold" FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <material:PackIconMaterial Kind="Play" Width="14" Height="14"
                              Foreground="White" Margin="0,0,6,0"/>
                        <TextBlock Text="Connect" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button x:Name="DisconnectButton"
                        Background="#F44747" Foreground="White"
                        Click="OnDisconnect" Padding="12,4" Margin="4,0" FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <material:PackIconMaterial Kind="Stop" Width="14" Height="14"
Margin="0,0,6,0"/>
                        <TextBlock Text="Disconnect" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Border Width="1" Background="#555" Margin="4,2" VerticalAlignment="Stretch"/>

                <Button Click="OnConfigClick"
                        Padding="12,4" Margin="4,0" FontSize="12"
                        ToolTip="打开配置窗口">
                    <StackPanel Orientation="Horizontal">
                        <material:PackIconMaterial Kind="Cog" Width="16" Height="16"
Margin="0,0,6,0"/>
                        <TextBlock Text="Config" Foreground="#E0E0E0"/>
                    </StackPanel>
                </Button>

                <TextBlock x:Name="tbStatus" Text="就绪" Foreground="#808080"
                           VerticalAlignment="Center" Margin="12,0,0,0" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- ═══ Main Content: 3-Column Layout ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="250" MaxWidth="700"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300" MinWidth="200" MaxWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Message Editor / Auto Reply Toggle -->
            <DockPanel Grid.Column="0" x:Name="LeftPanel">
                <!-- Tab Toggle -->
                <Border DockPanel.Dock="Top" Background="#252525" Padding="4,2">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="EditorTab" Content="消息编辑" IsChecked="True"
                                     Click="OnEditorTabClick" Margin="0,0,8,0" FontSize="11"
                                     Foreground="#E0E0E0"/>
                        <RadioButton x:Name="AutoReplyTab" Content="自动回复"
                                     Click="OnAutoReplyTabClick" FontSize="11"
                                     Foreground="#E0E0E0"/>
                    </StackPanel>
                </Border>

                <!-- Content Area -->
                <Grid>
                    <views:MessageEditorView x:Name="EditorView"
                            DataContext="{Binding MessageEditor}" Visibility="Visible"/>
                    <views:AutoReplyView x:Name="AutoReplyView"
                            DataContext="{Binding AutoReply}" Visibility="Collapsed"/>
                </Grid>
            </DockPanel>

            <!-- Splitter 1 -->
            <GridSplitter x:Name="Splitter1" Grid.Column="1" Width="4"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="#444444" ResizeBehavior="PreviousAndNext"/>

            <!-- Center: Message Log -->
            <views:MessageLogView Grid.Column="2" x:Name="MessageLogPanel"
                    DataContext="{Binding MessageLog}"/>

            <!-- Splitter 2 -->
            <GridSplitter x:Name="Splitter2" Grid.Column="3" Width="4"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="#444444" ResizeBehavior="PreviousAndNext"/>

            <!-- Right Panel: Status -->
            <views:StatusPanelView Grid.Column="4" x:Name="StatusPanel"
                    DataContext="{Binding StatusPanel}"/>
        </Grid>
    </DockPanel>
</mahApps:MetroWindow>
