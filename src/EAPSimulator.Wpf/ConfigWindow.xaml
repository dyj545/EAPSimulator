<Window x:Class="EAPSimulator.Wpf.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EAPSimulator.Wpf.Views"
        Title="Configuration" Width="360" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#1A1A1A">
    <views:ConfigView DataContext="{Binding Config}"/>
</Window>
